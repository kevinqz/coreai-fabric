{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core AI Catalog Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "family",
    "source_group",
    "source_path",
    "artifact_ref",
    "capabilities",
    "modalities",
    "artifact",
    "size",
    "runtime",
    "device_support",
    "license",
    "status",
    "maturity",
    "confidence",
    "sources",
    "last_verified",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "source_group": {
      "type": "string",
      "enum": ["zoo", "official", "external", "fabric", "unknown"]
    },
    "source_path": {
      "type": "string",
      "pattern": "^https://"
    },
    "artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "description": "What the model DOES — its tasks/behaviors. Controlled vocabulary: extend it only via a deliberate schema change, never ad-hoc. Architecture or inference properties (moe, mla, hybrid-llm, diffusion-lm, speculative-decoding) are NOT capabilities — put those in `traits`.",
      "items": {
        "type": "string",
        "enum": [
          "agentic",
          "audio-understanding",
          "chat",
          "code-generation",
          "document-ocr",
          "embedding",
          "gui-grounding",
          "image-generation",
          "image-text-similarity",
          "image-to-3d",
          "instance-segmentation",
          "instruction-following",
          "monocular-depth",
          "music-generation",
          "object-detection",
          "promptable-segmentation",
          "reasoning",
          "reranking",
          "robotics",
          "speech-to-text",
          "super-resolution",
          "text-generation",
          "text-to-audio",
          "text-to-speech",
          "text-to-video",
          "video-classification",
          "vision-language",
          "vision-language-action",
          "visual-document-retrieval"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "traits": {
      "type": "array",
      "description": "What the model IS inside — architecture or inference technique, orthogonal to what it does. Optional; most models have none. Controlled vocabulary, extended only via a deliberate schema change.",
      "items": {
        "type": "string",
        "enum": [
          "moe",
          "mla",
          "hybrid-llm",
          "diffusion-lm",
          "speculative-decoding"
        ]
      },
      "uniqueItems": true
    },
    "modalities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output"],
      "properties": {
        "input": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "availability"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["aimodel", "mlpackage", "unknown"]
        },
        "availability": {
          "type": "string",
          "enum": ["available", "unavailable", "unknown"]
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameters", "precision", "quantization", "artifact_size"],
      "properties": {
        "parameters": { "type": "string" },
        "precision": { "type": "string" },
        "quantization": { "type": "string" },
        "artifact_size": { "type": "string" },
        "fidelity_tier": {
          "type": "string",
          "enum": ["size", "balanced", "high_fidelity"],
          "description": "Quantization tier vs fidelity. `size` = size-optimized, lossy (e.g. int4 on Qwen — measured ~79% greedy argmax); `high_fidelity` = near-lossless (e.g. int8 absmax — ~96%/100%); `balanced` = in between. A `size`-tier model MUST NOT be described as lossless (audit-enforced)."
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_name",
        "runner",
        "stock_runtime",
        "custom_kernel",
        "patch_required",
        "tokenizer_required",
        "processor_required",
        "aot_required"
      ],
      "properties": {
        "runtime_name": {
          "type": "string",
          "enum": ["apple-core-ai", "coreml", "unknown"]
        },
        "runner": {
          "type": "string",
          "enum": [
            "CoreAIRunner",
            "stock-runner",
            "CoreAIDiffusionPipeline",
            "CoreAIImageSegmenter",
            "CoreAITranscribe",
            "CoreAIVideoPipeline",
            "CoreAIKit-GraphModel",
            "unknown"
          ]
        },
        "stock_runtime": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "custom_kernel": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "patch_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "tokenizer_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "processor_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "aot_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        }
      }
    },
    "device_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iphone", "ipad", "mac", "mac_only"],
      "properties": {
        "iphone": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "ipad": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "mac": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "mac_only": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "commercial_use"],
      "properties": {
        "name": { "type": "string" },
        "commercial_use": {
          "type": "string",
          "enum": ["likely", "check_license"]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["confirmed", "needs_review", "deprecated", "unknown"]
    },
    "maturity": {
      "type": "string",
      "enum": ["stable", "active", "experimental", "research", "unknown"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "needs_review"]
    },
    "sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "architecture": {
      "type": "string",
      "enum": ["transformer", "diffusion", "cnn/transformer", "encoder", "recurrent", "unknown"]
    },
    "context_window": {
      "type": ["string", "null"]
    },
    "streaming": {
      "type": "boolean"
    },
    "notes": {
      "type": ["string", "null"]
    },
    "bundle_kind": {
      "description": "Authored task-level bundle kind (redteam C5). Derived from the catalog's capability vocabulary — NOT the runtime's 4-value BundleKind enum (apple/coreai-models swift/Sources/CoreAIShared/Bundle/BundleKind.swift:12-17: llm/vlm/diffusion/segmenter). exports.py re-derives this from capabilities and fails the export on disagreement.",
      "type": "string",
      "enum": [
        "llm",
        "vlm",
        "ocr",
        "audio-lm",
        "embedding",
        "reranker",
        "object-detection",
        "segmentation",
        "depth",
        "image-generation",
        "super-resolution",
        "tts",
        "asr",
        "audio-generation",
        "video",
        "3d",
        "action"
      ]
    },
    "min_os": {
      "description": "Minimum OS version required by the model's runtime (redteam E5 / min_os data gap). For runtime_name apple-core-ai this is grounded in apple/coreai-models Package.swift: platforms: [.macOS(\"27.0\"), .iOS(\"27.0\")].",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "macos": { "type": "string", "pattern": "^\\d+(\\.\\d+)*$", "examples": ["27.0"] },
        "ios": { "type": "string", "pattern": "^\\d+(\\.\\d+)*$", "examples": ["27.0"] }
      }
    },
    "superseded_by": {
      "description": "Model id of the catalog entry that supersedes this one (lifecycle, redteam E4).",
      "type": "string",
      "minLength": 1,
      "examples": ["newer-model-id"]
    },
    "deprecation": {
      "description": "Deprecation record — set together with status: deprecated (lifecycle, redteam E4).",
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "reason"],
      "properties": {
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "upstream_repo": {
      "description": "Upstream source model repo as org/name (e.g. Qwen/Qwen3-0.6B) — the dedup key for discovery tooling (redteam F4). Real .aimodel bundles record this as metadata.json source.hf_model_id.",
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "examples": ["Qwen/Qwen3-0.6B"]
    },
    "variant_group": {
      "type": "string",
      "description": "Groups multiple quantization tiers of the SAME conversion (e.g. an int4 and int8 variant published to one HF repo). Models sharing a variant_group are tiers of one asset — consumers pick by size/fidelity. Typically the shared HF repo id."
    },
    "evaluation": {
      "description": "The measured Gate B parity signature (verbatim from the fabric parity-report gate_b), so the number reaches the registry instead of dying in a note. Mirrors the LIVE coreai-catalog schema (F13: one authority, no rejected additional properties). Keys vary by metric family; absent when unmeasured. The generic `value`/`min_cosine`/`protocol` fields live fabric-side in the recipe + generated scorecard pending the batched catalog schema PR (RFC §4.3).",
      "type": "object",
      "additionalProperties": false,
      "required": ["metric"],
      "properties": {
        "metric": { "type": "string" },
        "status": { "type": "string" },
        "reason": { "type": "string" },
        "margin_gated_match_rate": { "type": "number" },
        "margin_gated_ci95": { "type": "array", "items": { "type": "number" } },
        "argmax_match_rate": { "type": "number" },
        "top5_agreement_rate": { "type": "number" },
        "matched": { "type": "integer" },
        "compared": { "type": "integer" },
        "greedy_token_exact": { "type": "boolean" },
        "reference_dtype": { "type": "string" },
        "flip_margin_nats": { "type": "number" },
        "runner": { "type": "string" },
        "measured_on": { "type": "string" },
        "n_obs": { "type": "integer", "description": "Number of observations compared (action parity)." },
        "min_chunk_cosine": { "type": "number", "description": "Minimum chunk cosine similarity across all compared chunks (1.0 = perfect). Action parity metric." },
        "mean_chunk_cosine": { "type": "number" },
        "max_action_mae": { "type": "number", "description": "Maximum mean absolute error per action dimension." },
        "max_relative_action_mae": { "type": "number", "description": "Scale-invariant maximum relative MAE." },
        "framework": { "type": "string", "description": "Framework the parity was measured against (e.g. 'lerobot')." },
        "framework_version": { "type": "string" }
      }
    },
    "io_contract": {
      "description": "Machine-readable typed Swift-IO contract (redteam C1/C2/C6/C7, spec §3.3). Authored from the .aimodel bundle's real metadata (metadata.json / recipe.json in the pinned HF revision) plus the apple/coreai-models Swift API. Absent when the contract could not be verified — never guessed.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "framework": { "type": "string", "minLength": 1, "examples": ["CoreAILanguageModels"] },
            "type": { "type": "string", "minLength": 1, "examples": ["CoreAILanguageModel"] },
            "init_pattern": { "type": "string", "minLength": 1, "examples": ["try await CoreAILanguageModel(resourcesAt:)"] }
          }
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "modality"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "examples": ["prompt"] },
              "modality": { "type": "string", "minLength": 1, "examples": ["text"] },
              "swift_type": { "type": "string", "minLength": 1, "examples": ["String"] },
              "tensor": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "shape": {
                    "type": "array",
                    "items": { "type": ["integer", "string"] }
                  },
                  "dtype": { "type": "string" },
                  "layout": { "type": "string" }
                }
              },
              "preprocessing": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "resize": { "type": "string" },
                  "normalization": { "type": "string" },
                  "color_format": { "type": "string" },
                  "sample_rate": { "type": "integer" }
                }
              },
              "constraints": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "max_context": { "type": "integer" },
                  "max_image_px": { "type": "integer" },
                  "max_audio_s": { "type": "number" }
                }
              }
            }
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "examples": ["response"] },
              "swift_type": { "type": "string", "minLength": 1, "examples": ["String"] },
              "decoding": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "format_selector": { "type": "string" },
                  "coordinate_convention": { "type": "string" },
                  "label_vocab_ref": { "type": "string" },
                  "embedding_dim": { "type": "integer" },
                  "score_range": { "type": "string" },
                  "detokenization": { "type": "string" }
                }
              }
            }
          }
        },
        "session": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "stateful": { "type": "boolean" },
            "streaming": { "type": "boolean" }
          }
        },
        "files": {
          "description": "Paths inside the pinned HF revision of the artifact repo.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tokenizer_ref": { "type": "string", "examples": ["tokenizer"] },
            "processor_ref": { "type": "string", "examples": ["preprocessor_config.json"] }
          }
        }
      }
    }
  }
}
