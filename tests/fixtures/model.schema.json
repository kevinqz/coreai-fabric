{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core AI Catalog Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "family",
    "source_group",
    "source_path",
    "artifact_ref",
    "capabilities",
    "modalities",
    "artifact",
    "size",
    "runtime",
    "device_support",
    "license",
    "status",
    "maturity",
    "confidence",
    "sources",
    "last_verified",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "family": {
      "type": "string",
      "minLength": 1
    },
    "source_group": {
      "type": "string",
      "enum": ["zoo", "official", "external", "fabric", "unknown"]
    },
    "source_path": {
      "type": "string",
      "pattern": "^https://"
    },
    "artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "modalities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output"],
      "properties": {
        "input": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "availability"],
      "properties": {
        "format": {
          "type": "string",
          "enum": ["aimodel", "mlpackage", "unknown"]
        },
        "availability": {
          "type": "string",
          "enum": ["available", "unavailable", "unknown"]
        }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parameters", "precision", "quantization", "artifact_size"],
      "properties": {
        "parameters": { "type": "string" },
        "precision": { "type": "string" },
        "quantization": { "type": "string" },
        "artifact_size": { "type": "string" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_name",
        "runner",
        "stock_runtime",
        "custom_kernel",
        "patch_required",
        "tokenizer_required",
        "processor_required",
        "aot_required"
      ],
      "properties": {
        "runtime_name": {
          "type": "string",
          "enum": ["apple-core-ai", "coreml", "unknown"]
        },
        "runner": {
          "type": "string",
          "enum": [
            "CoreAIRunner",
            "stock-runner",
            "CoreAIDiffusionPipeline",
            "CoreAIImageSegmenter",
            "CoreAITranscribe",
            "CoreAIVideoPipeline",
            "CoreAIKit-GraphModel",
            "unknown"
          ]
        },
        "stock_runtime": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "custom_kernel": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "patch_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "tokenizer_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "processor_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "aot_required": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        }
      }
    },
    "device_support": {
      "type": "object",
      "additionalProperties": false,
      "required": ["iphone", "ipad", "mac", "mac_only"],
      "properties": {
        "iphone": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "ipad": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "mac": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        },
        "mac_only": {
          "type": ["boolean", "string"],
          "enum": [true, false, "unknown"]
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "commercial_use"],
      "properties": {
        "name": { "type": "string" },
        "commercial_use": {
          "type": "string",
          "enum": ["likely", "check_license"]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["confirmed", "needs_review", "deprecated", "unknown"]
    },
    "maturity": {
      "type": "string",
      "enum": ["stable", "active", "experimental", "research", "unknown"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "needs_review"]
    },
    "sources": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "architecture": {
      "type": "string",
      "enum": ["transformer", "diffusion", "cnn/transformer", "encoder", "recurrent", "unknown"]
    },
    "context_window": {
      "type": ["string", "null"]
    },
    "streaming": {
      "type": "boolean"
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
